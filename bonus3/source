#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <unistd.h>

int main(int argc, char *argv[]) {
    FILE*       fp;
    char buffer1[66];
    char buffer2[66];

    fp = fopen("/home/user/end/.pass", "r");

    memset(buffer1, 0, sizeof(buffer1));
    memset(buffer2, 0, sizeof(buffer2));

    if (fp == NULL){
        return -1;
    }

    if (argc != 2) {
        return -1;
    }

    fread(buffer1, 1, 66, fp);
    buffer1[65] = '\0';
    buffer1[atoi(argv[1])] = '\0';

    fread(buffer2, 1, 65, fp);

    fclose(fp);

    if (strcmp(buffer1, argv[1]) == 0) {
        execl("/bin/sh", "sh", NULL);
    } else {
        puts(buffer2);
    }

    return 0;
}