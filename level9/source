#include <stdlib.h>
#include <iostream>
#include <unistd.h>

class N {
public:
    char annotation[100];
    int value;

    N(int val) {
        this->value = val;
    }

    void setAnnotation(char* src) {
        memcpy(this->annotation, src, strlen(src));
    }

    virtual int operator+(N& other) {
        return this->value + other.value;
    }

    virtual int operator-(N& other) {
        return this->value - other.value;
    }
};

int main(int argc, char** argv) {
    if (argc <= 1)
        _exit(1);

    N* N1 = new N(5);
    N* N2 = new N(6);

    N1->setAnnotation(argv[1]);

    N2->operator+(*N1);

    return 0;
}